{
  "manifest_version": 3,
  "name": "ARBFast Buyer",
  "version": "1.4",
  "description": "Start and stop automatic order buying on arbpay.me",
  "permissions": ["activeTab", "scripting", "storage", "tabs"],
  "host_permissions": ["https://arbpay.me/*"],
  "action": { "default_popup": "popup.html" },
  "icons": { "1024": "arb.jpg" }
}
