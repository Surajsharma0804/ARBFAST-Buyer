{
  "manifest_version": 3,
  "name": "ARBFast Buyer",
  "version": "1.5",
  "description": "Automatically buy ARB orders on arbpay.me at your exact target amount.",
  "permissions": ["activeTab", "scripting", "storage", "tabs"],
  "host_permissions": ["https://arbpay.me/*"],
  "action": { "default_popup": "popup.html" },
  "browser_specific_settings": {
    "gecko": {
      "id": "arbfast-buyer@arbpay.me",
      "strict_min_version": "128.0",
      "data_collection_permissions": {
        "required": ["none"],
        "optional": ["none"]
      }
    }
  },
  "icons": {
    "48":  "icon48.png",
    "96":  "icon96.png",
    "128": "icon128.png"
  },
}
